{
  "mcpServers": {
    "forgejo": {
      "command": "node",
      "args": [
        "dist/index.js"
      ],
      "env": {
        "FORGEJO_URL": "https://codeberg.org",
        "FORGEJO_ACCESS_TOKEN": "YOUR_FORGEJO_TOKEN",
        "FORGEJO_DEBUG": "false"
      },
      "disabled": false,
      "alwaysAllow": []
    }
  }
}